{
  "name": "trade_ai",
  "version": "0.5.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "start": "next dev -p 3000",
    "build": "node -v && next build",
    "build:stable": "next build --webpack",
    "postinstall": "node -e \"const major=Number(process.versions.node.split('.')[0]); if (major < 20) { console.log('Skipping prisma generate on Node <20'); } else { require('child_process').execSync('prisma generate', { stdio: 'inherit' }); }\"",
    "test:ui": "playwright test",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "data:smoke": "tsx scripts/data-smoke.ts",
    "api:smoke": "tsx scripts/api-provider-smoke.ts",
    "smoke:providers": "tsx scripts/api-provider-smoke.ts",
    "front-feed:build": "tsx scripts/build-front-feed-runtime.ts",
    "data:verify-render": "tsx scripts/verify-render-data.ts",
    "smoke:pre-apk": "tsx scripts/smoke-pre-apk.ts",
    "seed:test-alert": "tsx scripts/seed-test-live-alert.ts",
    "live:sync": "tsx scripts/sync-live-runtime.ts",
    "yfinance:scan": "python3 scripts/yfinance_kr_formula_scan.py",
    "backtest:kr1m": "python3 scripts/backtest_kr_1m_formulas.py",
    "backtest:kr-horizontal": "python3 scripts/backtest_kosdaq_horizontal_disclosures.py",
    "check:banned-copy": "tsx scripts/check-banned-copy.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tailwindcss/postcss": "4.3.0",
    "autoprefixer": "10.5.0",
    "lightweight-charts": "5.2.0",
    "lucide-react": "1.14.0",
    "mixpanel-browser": "2.78.0",
    "next": "16.2.6",
    "pg": "8.20.0",
    "postcss": "8.5.14",
    "prisma": "7.8.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "0.0.1",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.7.0",
    "@types/pg": "8.20.0",
    "@types/react": "~19.1.0",
    "tsx": "4.21.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": "24.x"
  },
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
