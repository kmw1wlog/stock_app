KIS_ENV=real
KIS_APP_KEY=
KIS_APP_SECRET=

# Common values:
# real  -> https://openapi.koreainvestment.com:9443
# paper -> https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=

# Verify against the current KIS portal before production use.
KIS_MINUTE_ENDPOINT=/uapi/domestic-stock/v1/quotations/inquire-time-itemchartprice
KIS_MINUTE_TR_ID=FHKST03010200

# J = domestic stock quote market group in common KIS examples.
KIS_MARKET_DIV_CODE=J

# Polling behavior
POLL_SECONDS=60
LOOKBACK_MINUTES=120
OUTPUT_DIR=./output
